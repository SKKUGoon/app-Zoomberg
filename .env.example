# Postgres news feed (mart.fact__news + mart.dim__city)
NEWS_DB_HOST=your-rds-host.ap-northeast-1.rds.amazonaws.com
NEWS_DB_PORT=5432
NEWS_DB_USER=postgres
NEWS_DB_PASSWORD=replace-with-strong-password
NEWS_DB_NAME=postgres
NEWS_DB_SSL=true

# X API
X_BEARER_TOKEN=your-bearer-token
X_ACCESS_TOKEN=your-access-token
X_SECRET_TOKEN=your-secret-token
X_CONSUMER_KEY=your-consumer-key
X_CONSUMER_SECRET=your-consumer-secret

# AIS Stream IO
AIS_STREAM_API_KEY=your-ais-stream-api-key
# Optional JSON array, defaults to global bbox [[[-90,-180],[90,180]]]
AIS_STREAM_BOUNDING_BOXES=[[[-90,-180],[90,180]]]
